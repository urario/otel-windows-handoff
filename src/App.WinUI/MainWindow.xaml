<Window
    x:Class="OtelWindowsHandoff.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="OTel Windows Handoff">
    <ScrollViewer>
        <Grid x:Name="RootGrid" Padding="24" RowSpacing="14" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" FontSize="24" FontWeight="SemiBold"
                       Text="画像ジョブパイプライン" />

            <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="入力フォルダー" />
            <TextBox x:Name="InputDirectoryTextBox" Grid.Row="1" Grid.Column="1" Text="./data/in" />

            <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="出力フォルダー" />
            <TextBox x:Name="OutputDirectoryTextBox" Grid.Row="2" Grid.Column="1" Text="./data/out" />

            <TextBlock Grid.Row="3" VerticalAlignment="Center" Text="OTel モード" />
            <ComboBox x:Name="OtelModeComboBox" Grid.Row="3" Grid.Column="1" SelectedIndex="2">
                <ComboBoxItem Content="off" />
                <ComboBoxItem Content="sdk" />
                <ComboBoxItem Content="otlp" />
            </ComboBox>

            <TextBlock Grid.Row="4" VerticalAlignment="Center" Text="並列度" />
            <NumberBox x:Name="ParallelismNumberBox" Grid.Row="4" Grid.Column="1"
                       Minimum="1" Maximum="32" Value="2" SpinButtonPlacementMode="Inline" />

            <TextBlock Grid.Row="5" VerticalAlignment="Top" Text="障害注入" />
            <StackPanel Grid.Row="5" Grid.Column="1" Spacing="8">
                <CheckBox x:Name="SlowReadCheckBox" Content="slow-read (10件ごとに3秒遅延)" />
                <CheckBox x:Name="AccessDeniedCheckBox" Content="access-denied (10件ごとにsave失敗)" />
            </StackPanel>

            <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="10">
                <Button x:Name="StartButton" Click="StartButton_Click" Content="開始" />
                <Button x:Name="StopButton" Click="StopButton_Click" Content="停止" IsEnabled="False" />
                <Button x:Name="FreezeButton" Click="FreezeButton_Click" Content="UIを30秒フリーズ"
                        ToolTipService.ToolTip="危険: UIスレッドを30秒ブロックし、意図的に「応答なし」を再現します。" />
            </StackPanel>

            <ProgressBar x:Name="ProgressBar" Grid.Row="7" Grid.ColumnSpan="2" Minimum="0" Maximum="1" />

            <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Spacing="4">
                <TextBlock x:Name="ProgressTextBlock" Text="処理済み 0 / 失敗 0" />
                <TextBlock x:Name="CurrentJobTextBlock" Text="現在のジョブ: -" />
                <TextBlock x:Name="StatusTextBlock" Text="待機中" TextWrapping="Wrap" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
